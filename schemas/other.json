{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://digibatt.org/schemas/other.json",
  "title": "Other Record",
  "description": "A generic resource record that does not fit other subcategory types",
  "type": "object",
  "required": ["title", "description", "category", "subcategory"],
  "additionalProperties": false,
  "properties": {
    "title": {
      "type": "string",
      "description": "Title or name of the resource"
    },
    "description": {
      "type": "string",
      "description": "Brief description of the resource"
    },
     "category": {
      "type": "string",
      "enum": ["cyclic-testing", "data-repositories", "data-standardisation", "simulation-and-parameterisation", "system-level-testing"],
      "description": "Main category this record belongs to"
    },
    "subcategory": {
      "type": "string",
      "enum": ["software", "publication", "tutorial", "dataset", "other"],
      "description": "Subcategory within the main category"
    },
    "link": {
      "type": "string",
      "format": "uri",
      "description": "URL to download or access the resource"
    },
    "doi": {
      "type": "string",
      "description": "Digital Object Identifier, e.g. 10.1000/xyz123"
    },
    "license": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Licence under which the resource is published"
    },
    "authors": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of creators"
    },
    "funding_source": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of funding_sources"
    }
  }
}
