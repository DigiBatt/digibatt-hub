{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://digibatt.org/schemas/databases.json",
  "title": "Database Record",
  "description": "A curated battery materials or performance database",
  "type": "object",
  "required": ["title", "description"],
  "additionalProperties": false,
  "properties": {
    "title": {
      "type": "string",
      "description": "Name of the database"
    },
    "description": {
      "type": "string",
      "description": "Brief description of the database"
    },
    "url": {
      "type": "string",
      "format": "uri",
      "description": "URL to access or query the database"
    },
    "access": {
      "type": "string",
      "description": "Access model, e.g. Open, Registered, Subscription"
    },
    "license": {
      "type": "string",
      "description": "Licence or terms of use"
    },
    "authors": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Maintainers or creators"
    },
    "body": {
      "type": "string",
      "description": "Optional additional markdown content for the record page"
    }
  }
}
