{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://digibatt.org/schemas/software.json",
  "title": "Software Record",
  "description": "A software tool relevant to battery modelling or data",
  "type": "object",
  "required": ["title", "description", "category", "subcategory"],
  "additionalProperties": false,
  "properties": {
    "title": {
      "type": "string",
      "description": "Name of the software"
    },
    "description": {
      "type": "string",
      "description": "Brief description of what the software does"
    },
    "category": {
      "type": "string",
      "enum": ["cyclic-testing", "data-repositories", "data-standardisation", "simulation", "system-level-testing"],
      "description": "Main category this record belongs to"
    },
    "subcategory": {
      "type": "string",
      "enum": ["software", "publication", "tutorial", "dataset", "other"],
      "description": "Subcategory within the main category"
    },
    "link": {
      "type": "string",
      "format": "uri",
      "description": "URL to download or access the software"
    },
    "repository": {
      "type": "string",
      "format": "uri",
      "description": "URL to the code repository"
    },    
    "documentation": {
      "type": "string",
      "format": "uri",
      "description": "URL to the code documentation"
    },        
    "doi": {
      "type": "string",
      "description": "Digital Object Identifier, e.g. 10.1000/xyz123"
    },
    "language": {
      "type": "string",
      "description": "Language which the software is written in"
    },    
    "license": {
      "type": "string",
      "description": "Licence under which the software is published"
    },
    "authors": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of software creators"
    },
    "funding_source": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of funding_sources"
    }
  }
}
