{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://digibatt.org/schemas/publications.json",
  "title": "Publication Record",
  "description": "A research publication related to battery modelling or data",
  "type": "object",
  "required": ["title", "category", "subcategory"],
  "additionalProperties": false,
  "properties": {
    "title": {
      "type": "string",
      "description": "Full title of the publication"
    },
    "description": {
      "type": "string",
      "description": "Abstract or brief summary"
    },
    "category": {
      "oneOf": [
        {
          "type": "string",
          "enum": ["cyclic-testing", "data-repositories", "data-standardisation", "simulation-and-parameterisation", "system-level-testing"]
        },
        {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["cyclic-testing", "data-repositories", "data-standardisation", "simulation-and-parameterisation", "system-level-testing"]
          }
        }
      ],
      "description": "Main category or categories this record belongs to. Can be a single string or an array of category strings."
    },
    "subcategory": {
      "type": "string",
      "enum": ["software", "publication", "tutorial", "dataset", "other"],
      "description": "Subcategory within the main category"
    },
    "link": {
      "type": "string",
      "format": "uri",
      "description": "URL to download or access the dataset"
    },
    "doi": {
      "type": "string",
      "description": "Digital Object Identifier, e.g. 10.1000/xyz123"
    },
    "license": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Licences under which the publication is published"
    },
    "authors": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of creators"
    },
   "year": {
      "type": ["integer", "string"],
      "description": "Publication year"
    },
    "publisher": {
      "type": "string",
      "description": "Publisher of the resource, e.g. journal name, website etc."
    },    
    "funding_source": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of funding_sources"
    }
  }
}
