{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://digibatt.org/schemas/datasets.json",
  "title": "Dataset Record",
  "description": "An experimental or simulation dataset for battery research",
  "type": "object",
  "required": ["title", "description", "category", "subcategory"],
  "additionalProperties": false,
  "properties": {
    "title": {
      "type": "string",
      "description": "Name or title of the dataset"
    },
    "description": {
      "type": "string",
      "description": "Brief description of the dataset contents"
    },
    "category": {
      "oneOf": [
        {
          "type": "string",
          "enum": ["cyclic-testing", "data-repositories", "data-standardisation", "simulation-and-parameterisation", "system-level-testing"]
        },
        {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["cyclic-testing", "data-repositories", "data-standardisation", "simulation-and-parameterisation", "system-level-testing"]
          }
        }
      ],
      "description": "Main category or categories this record belongs to. Can be a single string or an array of category strings."
    },
    "subcategory": {
      "type": "string",
      "enum": ["software", "publication", "tutorial", "dataset", "other"],
      "description": "Subcategory within the main category"
    },
    "link": {
      "type": "string",
      "format": "uri",
      "description": "URL to download or access the dataset"
    },
    "doi": {
      "type": "string",
      "description": "Digital Object Identifier, e.g. 10.1000/xyz123"
    },
    "file_formats": {
      "type": "array",
      "items": { "type": "string" },
      "description": "File formats contained in the dataset"
    },    
    "license": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Licence under which the dataset is published"
    },
    "authors": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of dataset creators"
    },
    "funding_source": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of funding_sources"
    }
  }
}
