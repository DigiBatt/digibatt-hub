{{- $records := slice -}}
{{- range .Site.RegularPages -}}
  {{- $record := dict
    "title"       .Title
    "description" (or .Params.description "")
    "category"    (or .Params.category "")
    "subcategory" (or .Params.subcategory "")
    "url"         .Permalink
  -}}
  {{- $records = $records | append $record -}}
{{- end -}}
{{ $records | jsonify }}
